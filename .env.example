# ─── Zennopay partner starter — environment ──────────────────────────────────
# Copy to `.env` and fill in the values from your Zennopay onboarding pack.
# `.env` is gitignored. NEVER commit real credentials.

# Zennopay API base URL — from your onboarding pack.
# Sandbox (default): https://api.sandbox.zennopay.com
# Production:        https://api.zennopay.com  (only after go-live review)
ZENNOPAY_BASE_URL=https://api.sandbox.zennopay.com

# Your HMAC key id + shared secret (server-to-server API auth).
# Issued per environment — sandbox and production packs differ.
ZENNOPAY_HMAC_KEY_ID=your_key_id_here
ZENNOPAY_HMAC_SECRET=your_hmac_secret_here

# Your RS256 JWT signing key: base64 of the PKCS#8 PEM private key.
# Generate a pair:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private_pkcs8.pem
#   openssl pkey -in jwt_private_pkcs8.pem -pubout -out jwt_public_spki.pem
# Register the PUBLIC key with Zennopay (dashboard → API keys → JWT keys),
# then encode the PRIVATE key for this var:
#   base64 -i jwt_private_pkcs8.pem | tr -d '\n'
ZENNOPAY_JWT_PRIVATE_KEY_B64=base64_of_your_pkcs8_pem_here

# The key id ("kid") you registered alongside the public key.
ZENNOPAY_JWT_KID=your-jwt-kid-1

# Your issuer URL, exactly as registered with Zennopay.
ZENNOPAY_JWT_ISS=https://yourcompany.example/issuer

# Webhook verification secret — from the dashboard when you register your
# webhook endpoint. Optional until week 3; the webhook route answers 501
# until this is set.
# ZENNOPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Default corridor when the client omits one. vn_vietqr (Vietnam VietQR)
# or th_promptpay (Thailand PromptPay).
ZENNOPAY_DEFAULT_CORRIDOR=vn_vietqr

# HTTP port for this service.
PORT=8787

# ─── Sandbox-only toggles ────────────────────────────────────────────────────

# DANGER: issues FAKE KYC/sanctions attestations so you can exercise the
# sandbox before your compliance integration exists. Refused against
# production. Remove before go-live and implement src/attestations.ts.
# ATTESTATIONS_MODE=sandbox-stub

# Which partner_user_id `npm run verify` uses for its test intent.
# VERIFY_PARTNER_USER_ID=starter_verify_user
